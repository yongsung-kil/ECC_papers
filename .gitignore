# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/

# Data — PDF는 git 미추적(추후 업로드는 txt만), PDF에서 추출한 txt만 추적
data/pdfs/**
!data/pdfs/**/
!data/pdfs/**/*.txt
*.pdf
# (이전에 force-add된 2026 PDF는 git rm --cached로 추적 해제, txt만 유지)

# DB — papers.db는 GitHub에 함께 올림(단일 소스). WAL 보조 파일은 제외.
*.db
*.sqlite3
!data/papers.db
*.db-wal
*.db-shm

# IEEE 다운로더 산출물 (재다운로드 시 생성, git 제외)
tools/ieee_downloader/downloads/
tools/ieee_downloader/_staging*/

# Logs
logs/

# 선별 작업 스크래치 (실행별 _work/{타임스탬프}/ — DB가 영구 기록)
_work/
_pending_review.md
_judgments*.json
_batch/

# 개인 메모·임시 (스크래치)
tmp/

# IDE
.vscode/
.idea/

# Test
_test/

# PM
_pm/

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.local
